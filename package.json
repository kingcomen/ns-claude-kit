{
  "name": "ns-feature-template",
  "version": "1.0.0",
  "description": "NetSuite feature repo template — Claude Code two-loop workflow",
  "author": "Wichit Wongta",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.{js,ts}\"",
    "format": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "validate": "suitecloud project:validate",
    "deploy:sb": "suitecloud project:deploy",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:summary": "node tests/e2e/helpers/make-summary.js",
    "guide:capture": "node tests/guide/guide.capture.mjs",
    "guide:build": "node tests/guide/build-guide.mjs",
    "guide": "npm run guide:capture && npm run guide:build",
    "inner": "npm run lint && npm test",
    "outer": "npm run validate && npm run deploy:sb && npm run e2e && npm run e2e:summary",
    "ci": "npm run lint && npm test"
  },
  "devDependencies": {
    "@oracle/suitecloud-unit-testing": "^1.5.0",
    "@playwright/test": "^1.54.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.9.0",
    "jest": "^29.7.0",
    "otpauth": "^9.3.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
