# ─── Developer SB (local + outer loop) ───────────────────────────────────────
# แต่ละ dev ใช้ SB ของตัวเอง — ห้าม share ไฟล์นี้
NS_ACCOUNT_ID=1234567_SB1
NS_BASE_URL=https://1234567-sb1.app.netsuite.com

# Playwright login — ใช้ user ที่ปิด 2FA ใน SB หรือตั้ง NS_TOTP_SECRET
NS_EMAIL=dev-test-user@example.com
NS_PASSWORD=change-me

# TOTP: ใส่ base32 seed จากหน้า 2FA setup ของ NetSuite
# หากใช้ user ที่ปิด 2FA แล้ว ให้ comment ออก
NS_TOTP_SECRET=

# ─── ns-tdm RESTlet ───────────────────────────────────────────────────────────
# Deploy ns-tdm shared repo ลง SB ของตัวเองก่อน (ดู ns-tdm/README.md)
# seed / teardown dispatch ผ่าน body — ใช้ URL เดียวกัน
TDM_URL=https://1234567-sb1.app.netsuite.com/app/site/hosting/restlet.nl?script=customscript_ns_tdm&deploy=1

# ─── CI SB — TBA (GitHub Secrets เท่านั้น ห้าม commit) ──────────────────────
# ใส่ค่าเหล่านี้ใน GitHub Environment "sandbox-ci" ไม่ใช่ในไฟล์นี้
# สร้าง TBA token: NetSuite → Setup → Users/Roles → Access Tokens → New
# SUITECLOUD_AUTHID=ci-sb
# SUITECLOUD_TOKENID=
# SUITECLOUD_TOKENSECRET=
